use core.fs;

fn dispatch_host() -> i32 {
    let input_path = model.control.input_path()
    let output_path = model.control.output_path()
    let raw = fs.read_file(input_path)
    if raw == "" {
        discard fs.write_file(output_path, model.control.error_payload("control input missing"))
        return 12
    }
    discard fs.write_file(output_path, model.types.control_ok_json("dispatch_control", raw))
    return 0
}
