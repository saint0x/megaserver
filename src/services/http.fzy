fn handle_secrets_set(ctx: model.request.RequestContext, body_json: str, home: str) -> model.response.ResponsePlan {
    let parsed = model.request.parse_json_required(body_json, ctx.route_name)
    if parsed.ok == 0 {
        return request_error_plan(parsed.err)
    }
    let fields = list.new()
    let service = model.request.json_required_str(parsed.payload, "service", ctx.route_name)
    if service.ok == 0 {
        return request_error_plan(service.err)
    }
    let key = model.request.json_required_str(parsed.payload, "key", ctx.route_name)
    if key.ok == 0 {
        return request_error_plan(key.err)
    }
    let value = model.request.json_required_str(parsed.payload, "value", ctx.route_name)
    if value.ok == 0 {
        return request_error_plan(value.err)
    }
    discard list.push(fields, raw_string_field("service", service.value))
    discard list.push(fields, raw_string_field("key", key.value))
    discard list.push(fields, raw_string_field("value", value.value))
    return model.response.accepted_json(request_action_json("secret_set", fields, home))
}

