fn request_action_json_for_service(action: str, path: str, suffix: str, home: str) -> str {
    let fields = list.new()
    discard list.push(fields, raw_string_field("service", model.contracts.service_name_from_action_path(path, suffix)))
    return request_action_json(action, fields, home)
}
