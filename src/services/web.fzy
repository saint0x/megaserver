    web = fzweb.app.add_route(web, fzweb.app.route(model.contracts.route_id(model.contracts.RouteKind::RouteServiceDestroy), model.contracts.route_name(model.contracts.RouteKind::RouteServiceDestroy), "POST", "/v1/services/:service/destroy", model.contracts.route_prefix(model.contracts.RouteKind::RouteServiceDestroy), model.contracts.route_public(model.contracts.RouteKind::RouteServiceDestroy), model.contracts.route_skip_rate(model.contracts.RouteKind::RouteServiceDestroy), model.contracts.route_require_json(model.contracts.RouteKind::RouteServiceDestroy)))
