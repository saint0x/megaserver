fn openapi_path() -> str {
    return "/tmp/megaserver/openapi.json"
}

fn boot() -> i32 {
    discard fs.mkdir("/tmp/megaserver")
    discard fs.write_file(openapi_path(), fzweb.app.openapi_json(app()))
    return 0
}

fn routes_json() -> str {
    let web = app()
    let routes = list.new()
    let mut idx = 0
    while idx < fzweb.app.route_count(web) {
        let item = fzweb.app.route_at(web, idx)
        discard list.push(
            routes,
            json.raw(
                model.types.route_json(
                    item.route_id,
                    item.name,
                    item.method,
                    item.path,
                    item.group,
                    item.public_route,
                    item.skip_rate,
                    item.require_json,
                    route_auth(model.contracts.route_by_id(item.route_id)),
                ),
            ),
        )
        idx += 1
    }
    return json.array(routes)
}

fn route_count() -> i32 {
    return fzweb.app.route_count(app())
}

fn policy() -> fzweb.middleware.Policy {
    return fzweb.middleware.policy(1048576, 0, "", 1, 0, 1024)
}
