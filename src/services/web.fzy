    web = fzweb.app.add_route(web, fzweb.app.route(model.contracts.route_id(model.contracts.RouteKind::RouteServiceLogs), model.contracts.route_name(model.contracts.RouteKind::RouteServiceLogs), "GET", "/v1/services/:service/logs", model.contracts.route_prefix(model.contracts.RouteKind::RouteServiceLogs), model.contracts.route_public(model.contracts.RouteKind::RouteServiceLogs), model.contracts.route_skip_rate(model.contracts.RouteKind::RouteServiceLogs), model.contracts.route_require_json(model.contracts.RouteKind::RouteServiceLogs)))
