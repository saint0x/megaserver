    web = fzweb.app.add_route(web, fzweb.app.route(model.contracts.route_id(model.contracts.RouteKind::RouteServiceSnapshot), model.contracts.route_name(model.contracts.RouteKind::RouteServiceSnapshot), "POST", "/v1/services/:service/snapshot", model.contracts.route_prefix(model.contracts.RouteKind::RouteServiceSnapshot), model.contracts.route_public(model.contracts.RouteKind::RouteServiceSnapshot), model.contracts.route_skip_rate(model.contracts.RouteKind::RouteServiceSnapshot), model.contracts.route_require_json(model.contracts.RouteKind::RouteServiceSnapshot)))
    web = fzweb.app.add_route(web, fzweb.app.route(model.contracts.route_id(model.contracts.RouteKind::RouteServiceRollback), model.contracts.route_name(model.contracts.RouteKind::RouteServiceRollback), "POST", "/v1/services/:service/rollback/:snapshot", model.contracts.route_prefix(model.contracts.RouteKind::RouteServiceRollback), model.contracts.route_public(model.contracts.RouteKind::RouteServiceRollback), model.contracts.route_skip_rate(model.contracts.RouteKind::RouteServiceRollback), model.contracts.route_require_json(model.contracts.RouteKind::RouteServiceRollback)))
    web = fzweb.app.add_route(web, fzweb.app.route(model.contracts.route_id(model.contracts.RouteKind::RouteRoutesList), model.contracts.route_name(model.contracts.RouteKind::RouteRoutesList), "GET", "/v1/routes", model.contracts.route_prefix(model.contracts.RouteKind::RouteRoutesList), model.contracts.route_public(model.contracts.RouteKind::RouteRoutesList), model.contracts.route_skip_rate(model.contracts.RouteKind::RouteRoutesList), model.contracts.route_require_json(model.contracts.RouteKind::RouteRoutesList)))
    web = fzweb.app.add_route(web, fzweb.app.route(model.contracts.route_id(model.contracts.RouteKind::RouteRoutesCreate), model.contracts.route_name(model.contracts.RouteKind::RouteRoutesCreate), "POST", "/v1/routes", model.contracts.route_prefix(model.contracts.RouteKind::RouteRoutesCreate), model.contracts.route_public(model.contracts.RouteKind::RouteRoutesCreate), model.contracts.route_skip_rate(model.contracts.RouteKind::RouteRoutesCreate), model.contracts.route_require_json(model.contracts.RouteKind::RouteRoutesCreate)))
    web = fzweb.app.add_route(web, fzweb.app.route(model.contracts.route_id(model.contracts.RouteKind::RouteRoutesSign), model.contracts.route_name(model.contracts.RouteKind::RouteRoutesSign), "POST", "/v1/routes/signed-link", model.contracts.route_prefix(model.contracts.RouteKind::RouteRoutesSign), model.contracts.route_public(model.contracts.RouteKind::RouteRoutesSign), model.contracts.route_skip_rate(model.contracts.RouteKind::RouteRoutesSign), model.contracts.route_require_json(model.contracts.RouteKind::RouteRoutesSign)))
    web = fzweb.app.add_route(web, fzweb.app.route(model.contracts.route_id(model.contracts.RouteKind::RouteVolumesList), model.contracts.route_name(model.contracts.RouteKind::RouteVolumesList), "GET", "/v1/volumes", model.contracts.route_prefix(model.contracts.RouteKind::RouteVolumesList), model.contracts.route_public(model.contracts.RouteKind::RouteVolumesList), model.contracts.route_skip_rate(model.contracts.RouteKind::RouteVolumesList), model.contracts.route_require_json(model.contracts.RouteKind::RouteVolumesList)))
    web = fzweb.app.add_route(web, fzweb.app.route(model.contracts.route_id(model.contracts.RouteKind::RouteVolumesCreate), model.contracts.route_name(model.contracts.RouteKind::RouteVolumesCreate), "POST", "/v1/volumes", model.contracts.route_prefix(model.contracts.RouteKind::RouteVolumesCreate), model.contracts.route_public(model.contracts.RouteKind::RouteVolumesCreate), model.contracts.route_skip_rate(model.contracts.RouteKind::RouteVolumesCreate), model.contracts.route_require_json(model.contracts.RouteKind::RouteVolumesCreate)))
    web = fzweb.app.add_route(web, fzweb.app.route(model.contracts.route_id(model.contracts.RouteKind::RouteSecretsList), model.contracts.route_name(model.contracts.RouteKind::RouteSecretsList), "GET", "/v1/secrets", model.contracts.route_prefix(model.contracts.RouteKind::RouteSecretsList), model.contracts.route_public(model.contracts.RouteKind::RouteSecretsList), model.contracts.route_skip_rate(model.contracts.RouteKind::RouteSecretsList), model.contracts.route_require_json(model.contracts.RouteKind::RouteSecretsList)))
    web = fzweb.app.add_route(web, fzweb.app.route(model.contracts.route_id(model.contracts.RouteKind::RouteSecretsSet), model.contracts.route_name(model.contracts.RouteKind::RouteSecretsSet), "POST", "/v1/secrets", model.contracts.route_prefix(model.contracts.RouteKind::RouteSecretsSet), model.contracts.route_public(model.contracts.RouteKind::RouteSecretsSet), model.contracts.route_skip_rate(model.contracts.RouteKind::RouteSecretsSet), model.contracts.route_require_json(model.contracts.RouteKind::RouteSecretsSet)))
