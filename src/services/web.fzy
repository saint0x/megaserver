use core.fs;

fn route_auth(kind: model.contracts.RouteKind) -> str {
    if model.contracts.route_public(kind) == 1 {
        return "public"
    }
    return "operator"
}

fn app() -> fzweb.app.App {
    let mut web = fzweb.app.make("megaserver", "0.1")
    web = fzweb.app.use_middleware(web, "json")
    web = fzweb.app.use_middleware(web, "rate_limit")
    web = fzweb.app.use_middleware(web, "auth")

    web = fzweb.app.add_route(web, fzweb.app.route(model.contracts.route_id(model.contracts.RouteKind::RouteHealth), model.contracts.route_name(model.contracts.RouteKind::RouteHealth), "GET", "/v1/health", model.contracts.route_prefix(model.contracts.RouteKind::RouteHealth), model.contracts.route_public(model.contracts.RouteKind::RouteHealth), model.contracts.route_skip_rate(model.contracts.RouteKind::RouteHealth), model.contracts.route_require_json(model.contracts.RouteKind::RouteHealth)))
    web = fzweb.app.add_route(web, fzweb.app.route(model.contracts.route_id(model.contracts.RouteKind::RouteServicesList), model.contracts.route_name(model.contracts.RouteKind::RouteServicesList), "GET", "/v1/services", model.contracts.route_prefix(model.contracts.RouteKind::RouteServicesList), model.contracts.route_public(model.contracts.RouteKind::RouteServicesList), model.contracts.route_skip_rate(model.contracts.RouteKind::RouteServicesList), model.contracts.route_require_json(model.contracts.RouteKind::RouteServicesList)))
