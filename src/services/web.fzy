    web = fzweb.app.add_route(web, fzweb.app.route(model.contracts.route_id(model.contracts.RouteKind::RouteServiceStart), model.contracts.route_name(model.contracts.RouteKind::RouteServiceStart), "POST", "/v1/services/:service/start", model.contracts.route_prefix(model.contracts.RouteKind::RouteServiceStart), model.contracts.route_public(model.contracts.RouteKind::RouteServiceStart), model.contracts.route_skip_rate(model.contracts.RouteKind::RouteServiceStart), model.contracts.route_require_json(model.contracts.RouteKind::RouteServiceStart)))
    web = fzweb.app.add_route(web, fzweb.app.route(model.contracts.route_id(model.contracts.RouteKind::RouteServiceStop), model.contracts.route_name(model.contracts.RouteKind::RouteServiceStop), "POST", "/v1/services/:service/stop", model.contracts.route_prefix(model.contracts.RouteKind::RouteServiceStop), model.contracts.route_public(model.contracts.RouteKind::RouteServiceStop), model.contracts.route_skip_rate(model.contracts.RouteKind::RouteServiceStop), model.contracts.route_require_json(model.contracts.RouteKind::RouteServiceStop)))
