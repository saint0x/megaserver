{
  "version": 1,
  "name": "host-pass",
  "steps": [
    { "type": "fs_write", "path": "tmp/host-smoke.txt", "data": "hello-host" },
    { "type": "fs_read_assert", "path": "tmp/host-smoke.txt", "equals": "hello-host" },
    { "type": "proc_spawn", "cmd": "echo", "args": ["fz-host"], "expect_exit": 0, "expect_stdout": "fz-host\n" }
  ]
}